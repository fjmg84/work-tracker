{
  "name": "work-tracker",
  "version": "1.0.0",
  "description": "App de escritorio para registrar horas de trabajo, proyectos, PRs y commits de GitHub, y generar reportes mensuales en CSV.",
  "main": "electron/dist/main.js",
  "author": "Work Tracker",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run build:electron && wait-on http://localhost:5170 && npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.node.json",
    "pack:base": "vite build && npm run build:electron",
    "build:mac": "npm run pack:base && electron-builder --mac",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.worktracker.app",
    "productName": "Work Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "better-sqlite3": "^11.0.2",
    "date-fns": "^3.6.0",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "ui-ux-pro-max-cli": "^2.10.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.2",
    "vite": "^5.3.2",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  }
}
