{
  "name": "work-tracker",
  "version": "1.0.0",
  "description": "App de escritorio para registrar horas de trabajo, proyectos, PRs y commits de GitHub, y generar reportes mensuales en CSV.",
  "main": "electron/dist/main.js",
  "author": "Work Tracker",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run build:electron && wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.node.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "better-sqlite3": "^11.0.2",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.2",
    "wait-on": "^7.2.0"
  }
}
